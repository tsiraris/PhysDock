# ==========================================
# 1. Python & Packaging
# ==========================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
dist/
build/
sdist/
wheelhouse/
*.whl

# ==========================================
# 2. Virtual Environments
# ==========================================
.venv/
venv/
ENV/
env/

# ==========================================
# 3. Jupyter Notebooks & Checkpoints
# ==========================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/
.pytest_cache/
.tox/
.coverage
htmlcov/

# ==========================================
# 4. Data & Chemistry/Structural Biology Artifacts
# ==========================================
# Ignore bulky / regenerable data, but keep the directory structure.
data/raw/*
data/cache/*
data/processed/*
weights/

# Keep .gitkeep placeholders so empty dirs survive in git
!data/raw/.gitkeep
!data/cache/.gitkeep
!data/processed/.gitkeep

# Keep the prepared state file and the cleaned reference poses (small, needed for
# reproducibility and RMSD evaluation). The raw multi-copy *.sdf stay ignored.
!data/processed/target_prep.json
!data/processed/*_clean.sdf
!data/processed/*_receptor.pdb

# ==========================================
# 5. Results — ignore heavy intermediates, KEEP lightweight evidence
# ==========================================
# Ignore everything under results/ by default...
results/*
# ...then re-include the small, reviewer-facing deliverables.
# (Parent dirs must be un-ignored before nested files can be kept.)
!results/report/
results/report/*
!results/report/report.md
!results/report/summary.json
!results/report/merged.csv
!results/report/figures/
!results/report/figures/**
!results/diffdock/
results/diffdock/*
!results/diffdock/poses.csv
!results/chem/
results/chem/*
!results/chem/chem_gate.csv
!results/physics/
results/physics/*
!results/physics/physics.csv
!results/ensemble/
results/ensemble/*
!results/ensemble/ensemble.csv
!results/boltz/
results/boltz/*
!results/boltz/boltz.csv
# Note: results/boltz/preds/** (MSAs, PDBs, tensors — hundreds of MB) stays ignored.

# ==========================================
# 6. Molecular structures (global rules)
# ==========================================
*.cif
!data/ligands/*.csv

# ==========================================
# 7. MLOps, Tracking & IDEs
# ==========================================
wandb/
mlruns/
.lightning/
.tensorboard/
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ==========================================
# 8. OS & System Specific
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Icon?

# ==========================================
# 9. Office, Archives & Tools
# ==========================================
*.zip
*.tar.gz
*.rar
*.7z
*.doc
*.docx
*.xml
# Note: *.pdf and *.png are NOT ignored — figures render on GitHub.