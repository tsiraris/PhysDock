# ==========================================
# 4. Data & Chemistry/Structural Biology Artifacts
# ==========================================
# Ignore all data contents but keep the directory structures
data/raw/*
data/cache/*
data/processed/*
results/
weights/

# Keep standard gitkeep files
!data/raw/.gitkeep
!data/cache/.gitkeep
!data/processed/.gitkeep

# Molecular & Chemistry structures (Ignored except specific reference CSVs)
*.pdb
*.cif
*.sdf
!data/ligands/*.csv

